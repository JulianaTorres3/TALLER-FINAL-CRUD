{
  "info": {
    "_postman_id": "0d15e9e0-8a1a-42c2-8bb4-0b15f070b14c",
    "name": "Zoo Fantastic - CRUD Pruebas",
    "description": "Colección de pruebas de sistema para el CRUD de Mascotas Fantásticas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Creature",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Creature created successfully\", function () {",
              "    pm.response.to.have.status(200);",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql(\"Dragón\");",
              "    pm.environment.set(\"creatureId\", jsonData.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Dragón\",\n  \"species\": \"Fuego\",\n  \"size\": 25.0,\n  \"dangerLevel\": 10,\n  \"healthStatus\": \"healthy\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/creatures",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "creatures"
          ]
        }
      }
    },
    {
      "name": "2. Get All Creatures",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Creatures retrieved successfully\", function () {",
              "    pm.response.to.have.status(200);",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an(\"array\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/creatures",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "creatures"
          ]
        }
      }
    },
    {
      "name": "3. Get Creature By ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Creature retrieved successfully by ID\", function () {",
              "    pm.response.to.have.status(200);",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"id\");",
              "    pm.expect(jsonData.name).to.eql(\"Dragón\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/creatures/{{creatureId}}",
          "protocol": "http",
